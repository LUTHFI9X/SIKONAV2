# ===========================================
# SiKONA API - Production Environment
# ===========================================

APP_NAME=SiKONA
APP_ENV=production
APP_KEY=base64:GENERATE_NEW_KEY_FOR_PRODUCTION
APP_DEBUG=false
APP_URL=https://api.sikona.com

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

# ===========================================
# Database Configuration
# ===========================================
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=sikona_db
DB_USERNAME=sikona_user
DB_PASSWORD=your_secure_password

# ===========================================
# Session & Cache
# ===========================================
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true

CACHE_STORE=database

# ===========================================
# Sanctum Configuration
# ===========================================
SANCTUM_STATEFUL_DOMAINS=sikona.com,www.sikona.com,localhost:3000

# ===========================================
# CORS - Frontend URLs
# ===========================================
FRONTEND_URL=https://sikona.com

# ===========================================
# Mail Configuration
# ===========================================
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@sikona.com
MAIL_FROM_NAME="${APP_NAME}"

# ===========================================
# Filesystem
# ===========================================
FILESYSTEM_DISK=public

# ===========================================
# Queue (optional)
# ===========================================
QUEUE_CONNECTION=database
