{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "watchPatterns": [
      "/backend/**"
    ]
  },
  "deploy": {
    "startCommand": "php artisan serve --host=0.0.0.0 --port=${PORT:-8080}",
    "healthcheckPath": "/up",
    "healthcheckTimeout": 300,
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
